// Thoth Plugin Interface — v0.1.0
//
// This file is the official plugin SDK. Plugin authors in any language
// (Rust, Go, TypeScript, Python, C, ...) generate their bindings from this
// file using the appropriate WIT toolchain for their language.
//
// Toolchains:
//   Rust       → cargo-component (https://github.com/bytecodealliance/cargo-component)
//   TypeScript → jco             (https://github.com/bytecodealliance/jco)
//   Go         → wit-bindgen-go  (https://github.com/bytecodealliance/wit-bindgen)
//   Python     → componentize-py (https://github.com/bytecodealliance/componentize-py)
//
// ---------------------------------------------------------------------------
// CHANGELOG — breaking changes introduced since the initial release
// ---------------------------------------------------------------------------
//
// [BREAKING] plugin-lifecycle.on-load now takes a `setting: string` argument.
//   Migration: update your on_load implementation to accept the settings
//   string (JSON array of {key, value} pairs) instead of taking no arguments.
//
// [BREAKING] plugin-lifecycle.on-setting-change is now a required export.
//   Migration: implement on_setting_change (a no-op body is fine) in every
//   plugin that satisfies plugin-lifecycle.
//
// [BREAKING] base-plugin now includes plugin-settings, making render-settings
//   a required export on all plugin worlds (file-loader-plugin,
//   file-viewer-plugin, data-source-plugin, etc.).
//   Migration: implement render_settings() returning an empty UiNode, or
//   remove plugin-settings from base-plugin if the settings UI is optional
//   for your plugin type.
//
// [BREAKING] data-source.config-entry record now has four fields:
//   {name, description, required, value} — previously only {name, value}.
//   Migration: update ConfigEntry construction to supply description (human-
//   readable label) and required (bool) in addition to name and value.
//
// ---------------------------------------------------------------------------

package thoth:plugin@0.1.0;


// ---------------------------------------------------------------------------
// Shared types — imported by every interface below
// ---------------------------------------------------------------------------

interface types {

    /// Maps from src/wit/mod.rs `Capabilities` enum.
    /// Declare which of these your plugin implements in `plugin-info`.
    enum capability {
        file-loader,
        file-viewer,
        data-source,
        exporter,
        search-provider,
        new-ui-component,
    }

    /// Maps from src/wit/mod.rs `Plugin` struct.
    /// `location` is intentionally absent here — it is set by the host at
    /// discovery time (the path where the .wasm file lives) and is not
    /// something the plugin itself knows or declares.
    record plugin-info {
        id:           string,       // reverse-domain unique id, e.g. "com.example.csv-loader"
        name:         string,       // human-readable, e.g. "CSV Loader"
        version:      string,       // semver string, e.g. "0.2.1"
        description:  string,
        capabilities: list<capability>,
        author:       option<string>,
        homepage:     option<string>,
        /// Sidebar icon glyph. Use a phosphor icon Unicode character (e.g. "\u{E28C}").
        /// Falls back to a generic database icon when absent.
        icon:         option<string>,
    }

    /// Unified error type used across all interfaces.
    record plugin-error {
        code:    u32,
        message: string,
    }

    record setting-data {
        key:   string,
        value: string,
    }
}


// ---------------------------------------------------------------------------
// plugin-meta — required by every plugin
//
// Maps from src/wit/mod.rs `Plugin` struct (as the return type of get-info).
// ---------------------------------------------------------------------------

interface plugin-meta {
    use types.{plugin-info};

    /// Return static metadata about this plugin.
    /// Called once by the host immediately after instantiation.
    get-info: func() -> plugin-info;
}


// ---------------------------------------------------------------------------
// plugin-lifecycle — required by every plugin
//
// Maps directly from src/wit/mod.rs `PluginLifeCycle` trait.
// Note: WIT uses kebab-case, Rust uses snake_case — toolchains handle the
// conversion automatically.
// ---------------------------------------------------------------------------

interface plugin-lifecycle {
    /// Called by the host after the plugin is fully loaded and registered.
    /// Use this to initialise any internal state.
    /// Setting is passed in setting-data format, eg: "[{key: "url", value: "https://..."}, ...]"
    on-load: func(setting: string);

    /// Called by the host before the plugin is unloaded (app shutdown or
    /// the user disabling the plugin via Settings → Plugins).
    /// Release any held resources (open file handles, connections, etc.).
    on-close: func();

    /// Called by the host when the user saves settings in the plugin settings
    on-setting-change: func(setting: string);
}


// ---------------------------------------------------------------------------
// file-loader — implement when capability = file-loader
//
// Teaches Thoth to open a new file format. The host calls open() once,
// then calls get() lazily as the user scrolls. Maps to the core
// `FileLoader` trait in src/file/loaders/mod.rs.
// ---------------------------------------------------------------------------

interface file-loader {
    use types.{plugin-error};

    /// File extensions this plugin handles, without the leading dot.
    /// e.g. ["csv", "tsv"]
    supported-extensions: func() -> list<string>;

    /// Open the file at `path` and index it. Do NOT load all records into
    /// memory — just prepare for lazy access.
    /// Returns the total number of records (rows, objects, etc.) in the file.
    open: func(path: string) -> result<u64, plugin-error>;

    /// Return the record at `idx` serialised as a JSON string.
    /// Called lazily as the user scrolls — must be fast and stateless.
    get: func(idx: u64) -> result<string, plugin-error>;

    /// Return the raw bytes of the record at `idx` without JSON parsing.
    /// Used by the copy-to-clipboard and export paths.
    raw-bytes: func(idx: u64) -> result<list<u8>, plugin-error>;
}


// ---------------------------------------------------------------------------
// file-viewer — implement when capability = file-viewer
//
// Lets a plugin control how its records are *rendered* inside the viewer
// panel. Without this capability the host falls back to the default JSON
// tree renderer.
//
// Because WASM cannot call egui directly, the plugin returns a lightweight
// render-node tree (think virtual DOM). The host walks the tree and draws
// it with egui.
// ---------------------------------------------------------------------------

interface file-viewer {
    use types.{plugin-error};

    /// How the plugin wants its data displayed.
    ///
    /// table  — host renders a styled table using column-headers() and the raw
    ///          JSON values from file-loader.get(). render-record() is never
    ///          called. This is the simplest option: the plugin only needs to
    ///          declare headers and the host takes care of the rest.
    ///
    /// custom — host calls render-record() for every visible row and draws
    ///          the returned RenderNode tree. Use this when you need badges,
    ///          colours, links, nested tables, or any non-trivial cell content.
    enum display-mode {
        table,
        custom,
    }

    /// Declare how this plugin's data should be displayed.
    /// Called once after open(). Defaults to `table` if not implemented.
    preferred-display: func() -> display-mode;

    /// A node in the render tree.
    /// Recursive types are not allowed in WIT, so children are encoded as
    /// a JSON string following the RenderNode schema below.
    /// Schema (recursive):
    ///   { "type": "text",       "value": "hello" }
    ///   { "type": "bold",       "child": <RenderNode> }
    ///   { "type": "italic",     "child": <RenderNode> }
    ///   { "type": "colored",    "color": "#ff6b6b", "child": <RenderNode> }
    ///   { "type": "badge",      "label": "WARN", "color": "#fbca04" }
    ///   { "type": "link",       "label": "docs", "url": "https://..." }
    ///   { "type": "row",        "children": [<RenderNode>, ...] }
    ///   { "type": "column",     "children": [<RenderNode>, ...] }
    ///   { "type": "key-value",  "key": "id",  "value": <RenderNode> }
    ///   { "type": "collapsible","label": "...", "children": [<RenderNode>, ...] }
    ///   { "type": "table",      "headers": ["col1", ...], "rows": [[<RenderNode>, ...], ...] }
    ///   { "type": "json-tree",  "value": <any JSON value> }
    record render-output {
        /// JSON-encoded RenderNode tree (see schema above)
        node-json: string,
        /// Optional: height hint in logical pixels. 0 = auto.
        height-hint: u32,
    }

    /// Given a single record as a JSON string (as returned by file-loader's
    /// get()), return a render tree for the host to draw.
    render-record: func(record-json: string) -> result<render-output, plugin-error>;

    /// Optional custom column headers for the table view.
    /// Return `none` to use the keys from the first record as headers.
    column-headers: func() -> option<list<string>>;
}


// ---------------------------------------------------------------------------
// http-client — host-provided import for data-source plugins
//
// The host implements this interface using reqwest and exposes it to any
// plugin that imports it. All requests pass through the host's network-policy
// layer (domain allowlist, SSRF guard, rate limiter) before being forwarded.
// Using a host-provided import rather than wasi:http keeps compatibility with
// wasm32-wasip1 and centralises security enforcement.
// ---------------------------------------------------------------------------

interface http-client {
    use types.{plugin-error};

    record http-request {
        url:     string,
        method:  string,                        // "GET" | "POST" | "PUT" | "PATCH" | "DELETE"
        headers: list<tuple<string, string>>,   // additional headers
        body:    option<list<u8>>,              // request body (POST/PUT/PATCH)
    }

    record http-response {
        status:  u16,
        headers: list<tuple<string, string>>,
        body:    list<u8>,
    }

    /// Make an outbound HTTP request.
    /// The host enforces per-plugin network policy before forwarding.
    fetch: func(req: http-request) -> result<http-response, plugin-error>;

    /// Submit an HTTP request asynchronously. Returns an opaque request-id
    /// immediately without blocking. The host dispatches the request on a
    /// background thread and delivers the result by calling handle-event with:
    ///   widget-id = <request-id>
    ///   kind      = "http-response"
    ///   value     = JSON: {"ok":{"status":200,"headers":[["k","v"]],"body":"..."}}
    ///            or JSON: {"err":{"code":1,"message":"..."}}
    submit: func(req: http-request) -> string;
}


// ---------------------------------------------------------------------------
// plugin-storage — host-provided import for persistent per-plugin storage
//
// Each plugin gets a dedicated file on disk (managed by the host) where it
// can store arbitrary text data — typically a JSON snapshot of its state.
// The host decides the path; the plugin just reads and writes a string.
// Path: ~/.config/thoth/plugins/<plugin-id>/state.json
// ---------------------------------------------------------------------------

interface plugin-storage {
    /// Read the plugin's persisted state file.
    /// Returns the raw file contents, or an empty string if nothing has been
    /// saved yet (first run, or storage not available).
    read: func() -> string;

    /// Overwrite the plugin's persisted state file with `data`.
    /// Returns an error message string on failure.
    write: func(data: string) -> result<_, string>;
}


// ---------------------------------------------------------------------------
// data-source — implement when capability = data-source
//
// Connects Thoth to an external system: REST API, database, message queue,
// etc. The user triggers this from "Connect to source" in the toolbar.
// The host holds the returned handle string and passes it back on each call.
// ---------------------------------------------------------------------------

interface data-source {
    use types.{plugin-error};

    /// A key/value configuration entry supplied by the user (e.g. url, token).
    record config-entry {
        name:   string,
        description: string,
        required: bool,
        value: string,
    }

    /// Describes a single field in a schema.
    record field-schema {
        name:     string,
        type-hint: string,    // e.g. "string", "number", "boolean", "object"
        nullable: bool,
    }

    /// Describes a top-level entity (table, endpoint, collection, etc.).
    record source-schema {
        name:   string,
        fields: list<field-schema>,
    }

    /// The configuration keys this plugin requires.
    /// The host uses this to generate a "Connect to source" form dynamically.
    required-config: func() -> list<config-entry>;

    /// Establish a connection using the provided config.
    /// Returns an opaque handle string the host passes back on every call.
    connect: func(config: list<config-entry>) -> result<string, plugin-error>;

    /// Return available schemas (tables, endpoints, collections).
    /// Called after connect() to populate the source explorer sidebar.
    schema: func(handle: string) -> result<list<source-schema>, plugin-error>;

    /// Execute a query against the source.
    /// `q` is a free-form query string (SQL, JSONPath, filter DSL — up to the plugin).
    /// Returns a JSON-encoded array of record objects.
    query: func(handle: string, q: string) -> result<string, plugin-error>;

    /// Release the connection and free any held resources.
    close: func(handle: string);

    /// Render the current query result as a RenderNode tree for the main pane.
    /// Uses the same JSON schema as file-viewer's render-record.
    /// The plugin reads from its internal cache — call after query() succeeds.
    ///
    /// Schema (recursive, JSON-encoded):
    ///   { "type": "text",        "value": "hello" }
    ///   { "type": "bold",        "child": <RenderNode> }
    ///   { "type": "colored",     "color": "#ff6b6b", "child": <RenderNode> }
    ///   { "type": "badge",       "label": "200 OK", "color": "#10b981" }
    ///   { "type": "row",         "children": [<RenderNode>, ...] }
    ///   { "type": "column",      "children": [<RenderNode>, ...] }
    ///   { "type": "key-value",   "key": "id", "value": <RenderNode> }
    ///   { "type": "collapsible", "label": "Headers", "children": [...] }
    ///   { "type": "json-tree",   "value": <any JSON value> }
    record pane-output {
        node-json:   string,
        height-hint: u32,
    }
    render-pane: func(handle: string) -> result<pane-output, plugin-error>;
}


// ---------------------------------------------------------------------------
// exporter — implement when capability = exporter
//
// Adds a new export format or destination to the File → Export menu.
// ---------------------------------------------------------------------------

interface exporter {
    use types.{plugin-error};

    /// A user-configurable option shown in the export dialog.
    record export-option {
        key:           string,   // internal key
        label:         string,   // shown in the UI
        default-value: string,
        /// "text" | "bool" | "select" — drives the input widget type
        input-type:    string,
        /// Non-empty only when input-type = "select"
        choices:       list<string>,
    }

    /// Human-readable name for this format, e.g. "CSV Export"
    name: func() -> string;

    /// File extension for the output without the dot, e.g. "csv"
    output-extension: func() -> string;

    /// Options the host should display in the export dialog.
    available-options: func() -> list<export-option>;

    /// Perform the export.
    /// `records-json` is a JSON array string of all records to export.
    /// `options` is a flat key/value list of the user's chosen option values.
    /// Returns raw file bytes the host writes to disk.
    run: func(
        records-json: string,
        options: list<tuple<string, string>>,
    ) -> result<list<u8>, plugin-error>;
}

// ---------------------------------------------------------------------------
// ui-component — implement when capability = new-ui-component
//
// Lets a plugin render a fully interactive panel. The host calls render-ui()
// once to get the initial tree, then calls handle-event() every time the user
// interacts with a widget. The plugin owns all state — it receives the event,
// mutates its internal state, and returns a fresh tree.
//
// Because WASM cannot call egui directly, the plugin returns a lightweight
// UiNode tree (JSON-encoded). The host walks the tree, renders it with egui,
// and collects interaction events to feed back into the plugin.
//
// UiNode DSL — full schema
// ─────────────────────────────────────────────────────────────────────────────
// Every node is a JSON object with a mandatory "type" field (kebab-case).
// Optional fields use their documented default when absent.
//
// LAYOUT
//   { "type":"row",      "children":[UiNode,...], "gap":8,  "align":"start|center|end|fill" }
//   { "type":"column",   "children":[UiNode,...], "gap":4  }
//   { "type":"group",    "label":"Section",       "children":[UiNode,...] }
//   { "type":"scroll",   "child":UiNode,          "height":300            }
//   { "type":"spacer",   "height":8               }
//   { "type":"separator"                          }
//
// DISPLAY  (no id, no events)
//   { "type":"text",     "value":"hello",   "size":"sm|md|lg", "muted":true }
//   { "type":"heading",  "value":"Title",   "level":1          }
//   { "type":"badge",    "label":"WARN",    "color":"#f59e0b"  }
//   { "type":"code",     "value":"...",     "language":"json"  }
//   { "type":"markdown", "value":"**bold**"                    }
//   { "type":"progress", "value":0.75                          }
//
// INPUTS  (all have "id":string, "label":string, "disabled":false)
//   Fire a "change" event with the new value JSON-encoded in the `value` field.
//
//   { "type":"text-input",     "id":"url",   "label":"URL",
//                              "value":"",   "placeholder":"https://...", "required":true }
//   { "type":"number-input",   "id":"port",  "label":"Port",
//                              "value":8080, "min":1, "max":65535         }
//   { "type":"password-input", "id":"tok",   "label":"Token",  "value":"" }
//   { "type":"textarea",       "id":"body",  "label":"Body",
//                              "value":"",   "rows":5                     }
//   { "type":"select",         "id":"meth",  "label":"Method", "value":"GET",
//                              "options":[{"value":"GET","label":"GET"},...]  }
//   { "type":"multi-select",   "id":"tags",  "label":"Tags",   "value":["a"],
//                              "options":[{"value":"a","label":"Tag A"},...]  }
//   { "type":"checkbox",       "id":"ssl",   "label":"Verify SSL", "checked":true  }
//   { "type":"toggle",         "id":"en",    "label":"Enable",     "checked":false }
//   { "type":"radio",          "id":"auth",  "label":"Auth type",  "value":"none",
//                              "options":[{"value":"none","label":"None"},...]      }
//   { "type":"slider",         "id":"t",     "label":"Timeout",
//                              "value":30,   "min":1, "max":300            }
//   { "type":"key-value-list", "id":"hdrs",  "label":"Headers",
//                              "entries":[{"key":"...","value":"..."}],
//                              "add-label":"Add header"                    }
//
// ACTIONS  (fire a "click" event with an empty value)
//   { "type":"button",      "id":"send",  "label":"Send",
//                           "variant":"primary|secondary|danger", "enabled":true }
//   { "type":"icon-button", "id":"clear", "icon":"x",
//                           "tooltip":"Clear",                    "enabled":true }
// ---------------------------------------------------------------------------

interface ui-component {
    use types.{plugin-error};

    /// An event dispatched to the plugin when the user interacts with a widget.
    record ui-event {
        /// Matches the `id` field of the widget that fired the event.
        widget-id: string,
        /// "click"  — button / icon-button was pressed (value is empty)
        /// "change" — any input value changed (value is JSON-encoded new value)
        kind:      string,
        /// JSON-encoded new value:
        ///   text / password / textarea  → JSON string  e.g. "\"hello\""
        ///   number / slider             → JSON number  e.g. "42"
        ///   checkbox / toggle           → JSON bool    e.g. "true"
        ///   select / radio              → JSON string  e.g. "\"GET\""
        ///   multi-select                → JSON array   e.g. "[\"a\",\"b\"]"
        ///   key-value-list              → JSON array   e.g. "[{\"key\":\"k\",\"value\":\"v\"}]"
        ///   click                       → empty string
        value:     string,
    }

    /// Returned by both render-ui and handle-event.
    record ui-output {
        /// JSON-encoded UiNode tree (see DSL schema above).
        node-json:   string,
        /// Height hint in logical pixels. 0 = auto-size to content.
        height-hint: u32,
    }

    /// Return the initial UI tree. Called once when the panel is first shown.
    render-ui: func() -> result<ui-output, plugin-error>;

    /// Called every time the user interacts with a widget.
    /// The plugin updates its internal state and returns a fresh UI tree.
    handle-event: func(event: ui-event) -> result<ui-output, plugin-error>;

    /// Optional sidebar panel. Return `ok(some(...))` to claim a slot in the
    /// application sidebar (an icon button appears and the panel opens on click).
    /// Return `ok(none)` if this plugin has no sidebar content.
    /// The host calls this after every handle-event so the sidebar stays in sync.
    render-sidebar: func() -> result<option<ui-output>, plugin-error>;
}


// ---------------------------------------------------------------------------
// Worlds — plugin authors implement one of these
//
// A world declares exactly which interfaces a plugin exports. Pick the
// world that matches your plugin's capabilities. If you implement multiple
// capabilities, implement the combined world or compose component binaries.
// ---------------------------------------------------------------------------

// ---------------------------------------------------------------------------
// plugin-settings — implement on every plugin (trivial no-op is fine)
//
// Lets a plugin own its settings UI. The host calls render-settings() once
// with the persisted key/value pairs; the plugin returns a UiNode tree.
// Events from the UI (text-input changes, button clicks, etc.) are forwarded
// back via handle-setting-event(). On Save the host calls get-settings() to
// read the current values for persistence, and calls apply-settings() on the
// next load so the plugin can restore its state.
// ---------------------------------------------------------------------------

interface plugin-settings {
    use types.{plugin-error};

    record settings-output {
        /// JSON-encoded UiNode tree (same DSL as ui-component).
        node-json:   string,
        /// Height hint in logical pixels; 0 = auto.
        height-hint: u32,
    }

    /// Render the settings UI. Called once when the user opens the settings for this plugin.
    render-settings: func() -> result<settings-output, plugin-error>;
}


/// Every plugin must satisfy this base world.
world base-plugin {
    export plugin-meta;
    export plugin-lifecycle;
    export plugin-settings;
}

/// A plugin that teaches Thoth to open a new file format.
world file-loader-plugin {
    include base-plugin;
    export file-loader;
}

/// A plugin that opens a new file format AND controls how it is rendered.
world file-viewer-plugin {
    include base-plugin;
    export file-loader;
    export file-viewer;
}

/// A plugin that renders a fully interactive panel (no file-loading required).
world ui-component-plugin {
    include base-plugin;
    export ui-component;
}

/// A plugin that connects Thoth to an external data source and draws its own
/// connection / query UI panel via the ui-component interface.
/// The host provides the http-client import so plugins can make HTTP calls
/// without needing wasi:http or wasm32-wasip2.
world data-source-plugin {
    include base-plugin;
    import http-client;
    import plugin-storage;
    export data-source;
    export ui-component;
}

/// A plugin that adds a new export format or destination.
world exporter-plugin {
    include base-plugin;
    export exporter;
}
